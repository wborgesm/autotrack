generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plano {
  STARTER
  PROFISSIONAL
  BUSINESS
  ENTERPRISE
}

enum NivelAcesso {
  SUPER_ADMIN
  ADMIN
  GERENTE
  TECNICO
  RECEPCIONISTA
  CLIENTE
}

enum TipoVeiculo {
  CARRO
  MOTO
  UTILITARIO
  CAMINHAO
}

enum StatusOrdem {
  ABERTA
  EM_DIAGNOSTICO
  AGUARDANDO_PECAS
  EM_SERVICO
  TESTE_FINAL
  PRONTA
  ENTREGUE
  CANCELADA
}

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  CANCELADO
  CONCLUIDO
  NAO_COMPARECEU
}

enum TipoMovimentoEstoque {
  ENTRADA
  SAIDA
  AJUSTE
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

enum TipoTransacaoPontos {
  CREDITO
  DEBITO
  EXPIRACAO
}

enum NivelFidelidade {
  BRONZE
  PRATA
  OURO
  PLATINA
}

enum UnidadeMedida {
  UN
  L
  ML
  KG
  G
  M
  PAR
  JG
}

enum TipoOficina {
  CARROS
  MOTOS
  AMBOS
}

model Tenant {
  id            String  @id @default(cuid())
  nome          String
  cnpj          String?
  nif           String?
  website       String?
  telefone      String?
  email         String?
  endereco      String?
  logo          String?
  corPrimaria   String  @default("#3b82f6")
  corSecundaria String  @default("#1e40af")
  plano         Plano   @default(STARTER)
  ativo         Boolean @default(true)

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  whatsappNumero   String?
  whatsappStatus   String?   @default("DISCONNECTED")
  whatsappLigadoEm DateTime?

  onboardingCompleto Boolean @default(false)

  addonGps           Boolean @default(false)
  addonPontos        Boolean @default(false)
  addonWhatsapp      Boolean @default(false)
  addonPortalCliente Boolean @default(false)

  traccarUrl  String?
  traccarPort Int?
  traccarUser String?
  traccarPass String?

  pontosPorReal  Int @default(10)
  bonusMoto      Int @default(15)
  minimoResgate  Int @default(500)
  validadeMeses  Int @default(12)

  facebook  String?
  instagram String?
  tiktok    String?

  latitude      String?
  longitude     String?
  raioPermitido Int         @default(100)
  tipoOficina   TipoOficina @default(AMBOS)

  moloniDevId     String?
  moloniSecret    String?
  moloniEmail     String?
  moloniPass      String?
  moloniCompanyId String?

  usuarios          Usuario[]
  clientes          Cliente[]
  veiculos          Veiculo[]
  tecnicos          Tecnico[]
  servicos          Servico[]
  pecas             Peca[]
  movimentosEstoque MovimentoEstoque[]
  agendamentos      Agendamento[]
  ordensServico     OrdemServico[]
  lancamentos       LancamentoFinanceiro[]
  auditLogs         AuditLog[]
  traccarServers    TraccarServer[]
  orcamentos        Orcamento[]
  faturas           Fatura[]
  encomendas        Encomenda[]
  alugueres         Aluguer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

model Usuario {
  id               String      @id @default(cuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome             String
  email            String
  senha            String
  nivel            NivelAcesso @default(CLIENTE)
  ativo            Boolean     @default(true)
  twoFactorEnabled Boolean     @default(false)
  twoFactorSecret  String?
  permissoes       String[]
  avatar           String?
  faceDescriptor   Json?
  fotoReferenciaPath String?

  sessoes        Sessao[]
  registrosPonto RegistroPonto[]
  agendamentos   Agendamento[]
  ordensServico  OrdemServico[]
  tecnico        Tecnico?
  traccarServers TraccarServer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, nivel])
  @@index([tenantId, ativo])
  @@map("usuarios")
}

model Cliente {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome        String
  cpf         String?
  telefone    String?
  email       String?
  endereco    String?
  observacoes String?
  ativo       Boolean  @default(true)

  veiculos         Veiculo[]
  ordens           OrdemServico[]
  agendamentos     Agendamento[]
  pontosFidelidade PontosFidelidade?
  orcamentos       Orcamento[]
  faturas          Fatura[]
  encomendas       Encomenda[]
  alugueres        Aluguer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, cpf])
  @@index([tenantId, ativo])
  @@index([tenantId, nome])
  @@map("clientes")
}

model Veiculo {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteId String
  cliente   Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo      TipoVeiculo
  placa     String
  matricula String?
  marca     String
  modelo    String
  ano       Int?
  cor       String?
  combustivel String?
  km          Int?
  chassi      String?
  observacoes String?
  ativo       Boolean @default(true)

  imeiGps              String?
  dispositivoTraccarId Int?

  ordens       OrdemServico[]
  agendamentos Agendamento[]
  orcamentos   Orcamento[]
  encomendas   Encomenda[]
  alugueres    Aluguer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, placa])
  @@index([tenantId, clienteId])
  @@map("veiculos")
}

model Tecnico {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId String? @unique
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  nome          String
  especialidade String?
  telefone      String?
  ativo         Boolean @default(true)

  ordens         OrdemServico[]
  registrosTempo RegistroTempo[]
  agendamentos   Agendamento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, ativo])
  @@map("tecnicos")
}

model Servico {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome          String
  descricao     String?
  tipoVeiculo   TipoVeiculo?
  tempoEstMin   Int?
  precoMaoObra  Decimal  @db.Decimal(10, 2)
  ativo         Boolean  @default(true)

  itensOrdem     ItemOrdem[]
  agendamentos   Agendamento[]
  orcamentoItens OrcamentoItem[]
  encomendaItens EncomendaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, ativo])
  @@map("servicos")
}

model Peca {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codigo       String
  codigoBarras String?
  nome         String
  descricao    String?
  categoria    String?
  unidade      UnidadeMedida @default(UN)
  qtdEstoque   Decimal       @default(0) @db.Decimal(10, 2)
  qtdMinima    Decimal       @default(0) @db.Decimal(10, 2)
  quantidadeReservada Decimal? @default(0) @db.Decimal(10, 2)
  custoPadrao  Decimal?      @db.Decimal(10, 2)
  precoVenda   Decimal?      @db.Decimal(10, 2)
  margemLucro  Decimal?      @db.Decimal(5, 2)
  imagem       String?
  ativo        Boolean       @default(true)

  movimentos     MovimentoEstoque[]
  itensPeca      ItemPecaOrdem[]
  orcamentoItens OrcamentoItem[]
  reservas       ReservaPeca[]
  encomendaItens EncomendaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, codigo])
  @@index([tenantId, categoria])
  @@index([tenantId, ativo])
  @@map("pecas")
}

model MovimentoEstoque {
  id          String               @id @default(cuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pecaId      String
  peca        Peca                 @relation(fields: [pecaId], references: [id])
  tipo        TipoMovimentoEstoque
  quantidade  Decimal              @db.Decimal(10, 2)
  custo       Decimal?             @db.Decimal(10, 2)
  ordemId     String?
  ordem       OrdemServico?        @relation(fields: [ordemId], references: [id])
  encomendaId String?
  usuarioId   String?
  usuarioNome String?
  observacoes String?

  createdAt DateTime @default(now())

  @@index([tenantId, pecaId])
  @@index([tenantId, createdAt])
  @@index([ordemId])
  @@map("movimentos_estoque")
}

model Agendamento {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])
  veiculoId String
  veiculo   Veiculo @relation(fields: [veiculoId], references: [id])
  servicoId String?
  servico   Servico? @relation(fields: [servicoId], references: [id])
  tecnicoId String?
  tecnico   Tecnico? @relation(fields: [tecnicoId], references: [id])
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  dataHora    DateTime
  duracao     Int               @default(60)
  status      StatusAgendamento @default(PENDENTE)
  observacoes String?
  ordem       OrdemServico?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, dataHora])
  @@index([tenantId, status])
  @@index([tenantId, tecnicoId])
  @@map("agendamentos")
}

model OrdemServico {
  id            String  @id @default(cuid())
  numero        Int
  tenantId      String
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteId     String?
  cliente       Cliente? @relation(fields: [clienteId], references: [id])
  veiculoId     String?
  veiculo       Veiculo? @relation(fields: [veiculoId], references: [id])
  tecnicoId     String?
  tecnico       Tecnico? @relation(fields: [tecnicoId], references: [id])
  usuarioId     String?
  usuario       Usuario? @relation(fields: [usuarioId], references: [id])
  agendamentoId String?  @unique
  agendamento   Agendamento? @relation(fields: [agendamentoId], references: [id])

  status       StatusOrdem @default(ABERTA)
  kmEntrada    Int?
  kmSaida      Int?
  relatoCliente String?
  laudoTecnico  String?
  observacoes   String?

  fotos             String[]
  assinaturaCliente String?
  notasInternas     String?

  dataEntrada  DateTime  @default(now())
  dataPrevista DateTime?
  dataEntrega  DateTime?

  totalMaoObra Decimal @default(0) @db.Decimal(10, 2)
  totalPecas   Decimal @default(0) @db.Decimal(10, 2)
  desconto     Decimal @default(0) @db.Decimal(10, 2)
  total        Decimal @default(0) @db.Decimal(10, 2)
  pago         Boolean @default(false)
  estadoFiscal String? @default("SEM_DOCUMENTO")
  numFatura    String?

  itens             ItemOrdem[]
  itensPeca         ItemPecaOrdem[]
  historico         HistoricoOrdem[]
  lancamentos       LancamentoFinanceiro[]
  registrosTempo    RegistroTempo[]
  movimentosEstoque MovimentoEstoque[]
  faturas           Fatura[]
  reservas          ReservaPeca[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@index([tenantId, tecnicoId])
  @@index([tenantId, clienteId])
  @@index([tenantId, createdAt])
  @@map("ordens_servico")
}

model ItemOrdem {
  id        String       @id @default(cuid())
  ordemId   String
  ordem     OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  servicoId String
  servico   Servico      @relation(fields: [servicoId], references: [id])
  quantidade  Int
  valorUnit   Decimal @db.Decimal(10, 2)
  desconto    Decimal @default(0) @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  observacoes String?

  @@index([ordemId])
  @@map("itens_ordem")
}

model ItemPecaOrdem {
  id      String       @id @default(cuid())
  ordemId String
  ordem   OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  pecaId  String
  peca    Peca         @relation(fields: [pecaId], references: [id])
  quantidade Decimal @db.Decimal(10, 2)
  valorUnit  Decimal @db.Decimal(10, 2)
  desconto   Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  @@index([ordemId])
  @@map("itens_peca_ordem")
}

model HistoricoOrdem {
  id          String       @id @default(cuid())
  ordemId     String
  ordem       OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  status      StatusOrdem
  observacao  String?
  usuarioNome String

  createdAt DateTime @default(now())

  @@index([ordemId])
  @@map("historico_ordens")
}

model LancamentoFinanceiro {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ordemId  String?
  ordem    OrdemServico? @relation(fields: [ordemId], references: [id])

  tipo         TipoLancamento
  categoria    String?
  descricao    String
  valor        Decimal @db.Decimal(10, 2)
  data         DateTime @default(now())
  pago         Boolean  @default(false)
  estadoFiscal String?  @default("SEM_DOCUMENTO")
  numFatura    String?

  createdAt DateTime @default(now())

  @@index([tenantId, data])
  @@index([tenantId, tipo])
  @@index([tenantId, categoria])
  @@map("lancamentos_financeiros")
}

model Caixa {
  id             String    @id @default(cuid())
  tenantId       String
  usuarioId      String
  abertura       DateTime  @default(now())
  fechamento     DateTime?
  saldoInicial   Decimal   @default(0) @db.Decimal(10, 2)
  status         String    @default("ABERTA")
  saldoFinal     Decimal?  @db.Decimal(10, 2)
  totalVendas    Decimal?  @db.Decimal(10, 2)
  totalEsperado  Decimal?  @db.Decimal(10, 2)
  diferencaCaixa Decimal?  @db.Decimal(10, 2)
  justificativa  String?
  fechadoPor     String?
  vendas         Venda[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, abertura])
  @@map("caixas")
}

model Venda {
  id              String  @id @default(cuid())
  tenantId        String
  caixaId         String?
  caixa           Caixa?  @relation(fields: [caixaId], references: [id])
  total           Decimal @db.Decimal(10, 2)
  subtotal        Decimal @default(0) @db.Decimal(10, 2)
  desconto        Decimal @default(0) @db.Decimal(10, 2)
  metodoPagamento String
  usuarioId       String
  clienteId       String?
  observacoes     String?
  itens           VendaItem[]
  pagamentos      Pagamento[]

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([caixaId])
  @@map("vendas")
}

model VendaItem {
  id      String  @id @default(cuid())
  vendaId String
  venda   Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  tipo    String
  nome    String
  qtd     Int
  preco   Decimal @db.Decimal(10, 2)

  @@index([vendaId])
  @@map("venda_itens")
}

model Pagamento {
  id         String  @id @default(cuid())
  vendaId    String
  venda      Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  metodo     String
  valor      Float
  estado     String  @default("pago")
  referencia String?

  @@index([vendaId])
  @@map("pagamentos")
}

model Orcamento {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteId   String
  cliente     Cliente @relation(fields: [clienteId], references: [id])
  veiculoId   String?
  veiculo     Veiculo? @relation(fields: [veiculoId], references: [id])
  numero      Int
  descricao   String?
  status      String  @default("PENDENTE")
  total       Decimal @db.Decimal(10, 2)

  itens  OrcamentoItem[]
  fatura Fatura?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@map("orcamentos")
}

model OrcamentoItem {
  id          String    @id @default(cuid())
  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  tipo        String
  servicoId   String?
  servico     Servico? @relation(fields: [servicoId], references: [id])
  pecaId      String?
  peca        Peca?    @relation(fields: [pecaId], references: [id])
  quantidade  Int      @default(1)
  valorUnit   Decimal  @db.Decimal(10, 2)
  desconto    Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)

  @@map("orcamento_itens")
}

model Fatura {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  numero      String
  data        DateTime @default(now())
  clienteId   String
  cliente     Cliente @relation(fields: [clienteId], references: [id])
  ordemId     String?
  ordem       OrdemServico? @relation(fields: [ordemId], references: [id])
  orcamentoId String?  @unique
  orcamento   Orcamento? @relation(fields: [orcamentoId], references: [id])
  total       Decimal  @db.Decimal(10, 2)
  iva         Decimal  @default(23) @db.Decimal(5, 2)
  nifEmpresa  String
  emitida     Boolean  @default(false)
  pdfUrl      String?

  itens FaturaItem[]

  createdAt DateTime @default(now())

  @@index([tenantId, emitida])
  @@index([tenantId, createdAt])
  @@map("faturas")
}

model FaturaItem {
  id         String  @id @default(cuid())
  faturaId   String
  fatura     Fatura  @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  descricao  String
  quantidade Decimal @db.Decimal(10, 2)
  valorUnit  Decimal @db.Decimal(10, 2)
  iva        Decimal @default(23) @db.Decimal(5, 2)
  total      Decimal @db.Decimal(10, 2)

  @@index([faturaId])
  @@map("fatura_itens")
}

model ReservaPeca {
  id         String  @id @default(cuid())
  tenantId   String
  pecaId     String
  peca       Peca         @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  ordemId    String?
  ordem      OrdemServico? @relation(fields: [ordemId], references: [id], onDelete: SetNull)
  quantidade Decimal @db.Decimal(10, 2)
  criadoEm   DateTime @default(now())

  @@index([tenantId, pecaId])
  @@map("reservas_pecas")
}

model Encomenda {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteId    String?
  cliente      Cliente?  @relation(fields: [clienteId], references: [id])
  veiculoId    String?
  veiculo      Veiculo?  @relation(fields: [veiculoId], references: [id])
  descricao    String?
  tipo         String    @default("ENCOMENDA_OFICINA")
  dataPrevista DateTime?
  status       String    @default("PENDENTE")
  valorTotal   Decimal?  @db.Decimal(10, 2)
  itens        EncomendaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@map("encomendas")
}

model EncomendaItem {
  id            String    @id @default(cuid())
  encomendaId   String
  encomenda     Encomenda @relation(fields: [encomendaId], references: [id], onDelete: Cascade)
  tipo          String
  nome          String
  qtd           Int       @default(1)
  precoUnitario Decimal?  @db.Decimal(10, 2)
  pecaId        String?
  peca          Peca?    @relation(fields: [pecaId], references: [id])
  servicoId     String?
  servico       Servico? @relation(fields: [servicoId], references: [id])

  @@map("encomenda_itens")
}

model Aluguer {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteId   String
  cliente     Cliente   @relation(fields: [clienteId], references: [id])
  veiculoId   String
  veiculo     Veiculo   @relation(fields: [veiculoId], references: [id])
  dataInicio  DateTime
  dataFim     DateTime?
  valorDiaria Decimal   @db.Decimal(10, 2)
  valorTotal  Decimal?  @db.Decimal(10, 2)
  status      String    @default("ATIVO")
  observacoes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@map("alugueres")
}

model PontosFidelidade {
  id        String          @id @default(cuid())
  clienteId String          @unique
  cliente   Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pontos    Int             @default(0)
  nivel     NivelFidelidade @default(BRONZE)
  transacoes TransacaoPontos[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pontos_fidelidade")
}

model TransacaoPontos {
  id         String              @id @default(cuid())
  pontosId   String
  pontos     PontosFidelidade    @relation(fields: [pontosId], references: [id], onDelete: Cascade)
  tipo       TipoTransacaoPontos
  quantidade Int
  descricao  String?
  ordemId    String?
  expiracao  DateTime?

  createdAt DateTime @default(now())

  @@index([pontosId])
  @@map("transacoes_pontos")
}

model TraccarServer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  nome      String
  url       String
  port      Int      @default(443)
  username  String
  password  String
  ativo     Boolean  @default(true)
  ordem     Int      @default(1)

  @@unique([tenantId, usuarioId, nome])
  @@map("traccar_servers")
}

model RegistroTempo {
  id        String    @id @default(cuid())
  tenantId  String
  tecnicoId String?
  tecnico   Tecnico?  @relation(fields: [tecnicoId], references: [id])
  usuarioId String?
  ordemId   String?
  ordem     OrdemServico? @relation(fields: [ordemId], references: [id], onDelete: SetNull)
  tipo      String
  dataHora  DateTime
  observacao String?

  createdAt DateTime @default(now())

  @@index([tenantId, tecnicoId, dataHora])
  @@index([tenantId, usuarioId, dataHora])
  @@index([ordemId])
  @@map("registros_tempo")
}

model RegistroPonto {
  id             String  @id @default(cuid())
  usuarioId      String
  usuario        Usuario @relation(fields: [usuarioId], references: [id])
  dataHora       DateTime @default(now())
  latitude       Float
  longitude      Float
  fotoPath       String
  distanciaFace  Float?
  autenticado    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([usuarioId, dataHora])
  @@map("registros_ponto")
}

model Sessao {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  usuario   Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String?
  ip        String
  userAgent String?
  os        String?
  browser   String?
  ativo     Boolean  @default(true)
  lastSeenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, ativo])
  @@index([tenantId, lastSeenAt])
  @@map("sessoes")
}

model AuditLog {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId       String?
  usuarioNome     String
  acao            String
  entidade        String
  entidadeId      String?
  dadosAnteriores Json?
  dadosNovos      Json?

  createdAt DateTime @default(now())

  @@index([tenantId, entidade])
  @@index([tenantId, usuarioId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model AlertaFraude {
  id         String  @id @default(cuid())
  tenantId   String
  tipo       String
  gravidade  String
  descricao  String
  entidadeId String?
  resolvido  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([tenantId, resolvido])
  @@index([tenantId, createdAt])
  @@map("alertas_fraude")
}

model ChatLog {
  id          String   @id @default(cuid())
  tenantId    String
  usuarioId   String?
  usuarioNome String?
  nivel       String?
  pergunta    String
  resposta    String?
  fonte       String?
  matched     Boolean?
  util        Boolean?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, matched])
  @@index([tenantId, util])
  @@map("chat_logs")
}

model ChatCache {
  id       String   @id @default(cuid())
  pergunta String   @unique
  resposta String

  createdAt DateTime @default(now())

  @@map("chat_cache")
}

model Notificacao {
  id           String    @id @default(cuid())
  tenantId     String
  tipo         String
  destinatario String
  mensagem     String
  estado       String    @default("PENDENTE")
  ordemId      String?
  clienteId    String?
  erro         String?
  tentativas   Int       @default(0)
  enviadoEm    DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, estado])
  @@index([tenantId, createdAt])
  @@map("notificacoes")
}

model ConfiguracaoNotificacao {
  id                   String  @id @default(cuid())
  tenantId             String  @unique
  osProntaWhatsapp     Boolean @default(true)
  osProntaSms          Boolean @default(false)
  osProntaEmail        Boolean @default(false)
  osEntregueWhatsapp   Boolean @default(true)
  osEntregueEmail      Boolean @default(false)
  stockCriticoEmail    Boolean @default(true)
  stockCriticoWhatsapp Boolean @default(false)
  novaEncomendaEmail   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("configuracoes_notificacao")
}

model TemplateOS {
  id        String   @id @default(cuid())
  tenantId  String
  nome      String
  descricao String?
  servicos  String[]
  pecas     Json?
  ativo     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, ativo])
  @@map("templates_os")
}

model PendingTenant {
  id          String   @id @default(cuid())
  email       String
  nome        String
  plano       String
  addons      String
  total       Float
  gateway     String
  status      String   @default("PENDING")
  checkoutUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pending_tenants")
}
